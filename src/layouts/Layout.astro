---
import Header from "../components/Header.astro";
import '@fontsource-variable/onest/wght.css';

interface Props{
	title: string
	description: string
}

const {description, title} = Astro.props
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="inset-0 -z-10 h-full w-full items-center px-5 py-24 [background:radial-gradient(125%_125%_at_50%_10%,#000_40%,#63e_100%)] background-size: cover background-attachment: fixed 100vh"></div>

		<Header></Header>

		<slot />
	</body>
</html>

<style is:global>
	:root{
		color-scheme: light dark;
	}
	
	html {
		font-family: "Onest Variable", system-ui, sans-serif;
        
	}

	body {
		background: #050505;
		display: flex;
		flex-direction: column;

		height: 100vh;
	}
	
	.text-anim {
  display: inline-block;
  opacity: 0;
  transform: translateX(50px);
  transition: all 2s ease;

}

/* cuando entra en pantalla */
.text-anim.show {
  opacity: 1;
  transform: translateX(0);
}

</style>
