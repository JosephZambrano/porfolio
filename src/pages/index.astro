---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import LinkedInIcon from '../components/icons/LinkedInIcon.astro';
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import SocialIcon from '../components/icons/SocialIcons.astro';
import GmailIcon from '../components/icons/GmailIcon.astro';
import Experiencia from '../components/Experiencia.astro';
import Container from '../components/Container.astro';
import HtmlIcon from '../components/icons/HtmlIcon.astro';
import CssIcon from '../components/icons/CssIcon.astro';
import JsIcon from '../components/icons/JsIcon.astro';
import MySqlIcon from '../components/icons/MySqlIcon.astro';
import PhpIcon from '../components/icons/PhpIcon.astro';
import PythonIcon from '../components/icons/PythonIcon.astro';
import BookIcon from '../components/icons/BookIcon.astro';
import TailwindIcon from '../components/icons/TailwindIcon.astro';
import AstroIcon from '../components/icons/AstroIcon.astro';
---

<Layout 
title="Porfolio de Joseph - Desarrollador y Programador Web"
description="Contrata a Joseph para desarrollar proyectos a futuro.">
	<main>
		<Container>
			<h1 class=" text-white text-5xl font-bold flex flex-row gap-x-8 pb-5 py-16">
				Hey, soy Joseph  <a 
				href="https://www.linkedin.com/in/joseph-zambrano-188898272/" 
				target="_blank"
				rel="noopener"
				class="flex justify-center items-center hover:scale-110 transition"
				> 
				
				<Badge>Disponible para trabajar</Badge>

				</a>
				
			</h1>
			<h2 class="text-2xl opacity-80">
				Estudiante de desarrollo web. De Guayaquil, Ecuador 🇪🇨. <span class="text-purple-300/90">Especializado en crear aplicaciones únicas.</span>
			</h2>

			<nav class="flex gap-x-4 mt-6">
					<SocialIcon href="https://www.linkedin.com/in/joseph-zambrano-188898272/">  
						<LinkedInIcon class="size-8"></LinkedInIcon> 
					</SocialIcon>
				
					<SocialIcon href="https://github.com/JosephZambrano">  
						<GitHubIcon class="size-8"></GitHubIcon> 
					</SocialIcon>

					<SocialIcon href="mailto:jz09022005@gmail.com">  
						<GmailIcon class="size-8"></GmailIcon> 
					</SocialIcon>
			</nav>
		</Container>

		<Container>
			<div class="flex flex-col gap-y-4">
			<h2 class="text-white text-3xl font-bold flex gap-x-2">
				 Tecnologías
			</h2>

			<div class="flex flex-row gap-x-4 overflow-x-auto ">
				<HtmlIcon class="size-14 shrink-0" />
				<CssIcon class="size-14 shrink-0" />
				<JsIcon class="size-14 shrink-0" />
				<PythonIcon class="size-14 shrink-0" />
				<PhpIcon class="size-14 shrink-0" />
				<AstroIcon class="size-14 shrink-0" />
				<TailwindIcon class="size-14 shrink-0" />
				<MySqlIcon class="size-14 shrink-0" />	
			</div>
			</div>

		</Container>

		<Container>
		<div class="flex justify-center items-center ">
			<button
				type="button"
				class="text-white bg-brand border border-transparent hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium shadow-lg font-semibold rounded-full text-xl px-8 py-4 focus:outline-none transition-all duration-300 hover:scale-105"
			>
				<a href="cv.pdf" download>Descargar CV </a>
			</button>
			</div>
		</Container>

		<Container>
			<h2 id="formacion" class=" text-white text-3xl font-bold flex gap-x-2 pb-5 text-anim text-anim.show items-center ">
				<BookIcon class="size-7" />Formación
			</h2>
			<Experiencia></Experiencia>
		</Container>
	</main>
</Layout>
